import os
import random
import hashlib
import bcrypt

secret_env_path = 'secret.env'

if os.path.exists(secret_env_path):
    with open(secret_env_path, 'r') as f:
        content = f.read()
    has_username = 'PROMETHEUS_AUTH_USERNAME=' in content
    has_hashed_password = 'PROMETHEUS_AUTH_HASHED_PASSWORD=' in content
    has_password = 'PROMETHEUS_AUTH_PASSWORD=' in content
else:
    has_username = False
    has_hashed_password = False
    has_password = False

if os.path.exists(secret_env_path) and not has_username:
    # Generate new credentials if username doesn't exist
    prometheus_user = f'prometheus_{random.randint(0, 32767)}'
    prometheus_secret = hashlib.sha256(os.urandom(16)).hexdigest()
    hashed_password = bcrypt.hashpw(prometheus_secret.encode('utf-8'), bcrypt.gensalt(prefix=b"2b")).decode('utf-8')

    with open(secret_env_path, 'a') as f:
        f.write(f'PROMETHEUS_AUTH_USERNAME={prometheus_user}\n')
        f.write(f'PROMETHEUS_AUTH_PASSWORD={prometheus_secret}\n')
        f.write(f'PROMETHEUS_AUTH_HASHED_PASSWORD={hashed_password}\n')
elif os.path.exists(secret_env_path) and has_password and not has_hashed_password:
    # Extract existing password and hash it
    prometheus_secret = None
    with open(secret_env_path, 'r') as f:
        for line in f:
            if line.startswith('PROMETHEUS_AUTH_PASSWORD='):
                prometheus_secret = line.split('=', 1)[1].strip()
                break

    if prometheus_secret:
        hashed_password = bcrypt.hashpw(prometheus_secret.encode('utf-8'), bcrypt.gensalt(prefix=b"2b")).decode('utf-8')
        with open(secret_env_path, 'a') as f:
            f.write(f'PROMETHEUS_AUTH_HASHED_PASSWORD={hashed_password}\n')
